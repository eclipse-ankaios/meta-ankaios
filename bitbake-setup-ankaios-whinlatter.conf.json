{
    "version": "1.0",
    "description": "Ankaios bitbake-setup profiles for Yocto 5.3 Whinlatter",
    "sources": {
        "bitbake": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.openembedded.org/bitbake"
                    }
                },
                "branch": "2.16",
                "rev": "713fbbdb9ecc195ceb2216a2345e0d79dbee2135"
            }
        },
        "openembedded-core": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.openembedded.org/openembedded-core"
                    }
                },
                "branch": "whinlatter",
                "rev": "8751ec83421192fc0f8495fb95798f9eb7be77a0"
            }
        },
        "meta-yocto": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-yocto"
                    }
                },
                "branch": "whinlatter",
                "rev": "3f2e6b6fadfa542f0fe3738375a2f9fcbd4c1f6e"
            }
        },
        "meta-openembedded": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.openembedded.org/meta-openembedded"
                    }
                },
                "branch": "whinlatter",
                "rev": "f52f32952cb9717949f8bc3d3ccf6c4c5a59521f"
            }
        },
        "meta-virtualization": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-virtualization"
                    }
                },
                "branch": "whinlatter",
                "rev": "8f03a0cc8950ef5d5e4f11d9ae494946d1991e45"
            }
        },
        "meta-raspberrypi": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-raspberrypi"
                    }
                },
                "branch": "whinlatter",
                "rev": "469e232c77d74cb030fe8a9af4ffe9127214a29b"
            }
        }
    },
    "bitbake-setup": {
        "configurations": [
            {
                "bb-layers": [
                    "openembedded-core/meta",
                    "meta-yocto/meta-poky",
                    "meta-yocto/meta-yocto-bsp",
                    "meta-openembedded/meta-oe",
                    "meta-openembedded/meta-python",
                    "meta-openembedded/meta-networking",
                    "meta-openembedded/meta-filesystems",
                    "meta-virtualization",
                    "meta-raspberrypi"
                ],
                "bb-layers-file-relative": [
                    "."
                ],
                "oe-fragments": [
                    "distro/poky"
                ],
                "oe-fragments-one-of": {
                    "machine": {
                        "description": "Target machine",
                        "options": [
                            "machine/qemux86-64",
                            "machine/raspberrypi4-64",
                            "machine/raspberrypi5"
                        ]
                    }
                },
                "configurations": [
                    {
                        "name": "ankaios-sysvinit",
                        "description": "Poky distribution with Ankaios and SysVinit on Whinlatter",
                        "setup-dir-name": "ankaios-sysvinit-whinlatter-$machine",
                        "oe-fragments": [
                            "meta-ankaios/ankaios/minimal-sysvinit"
                        ]
                    },
                    {
                        "name": "ankaios-systemd",
                        "description": "Poky distribution with Ankaios and systemd on Whinlatter",
                        "setup-dir-name": "ankaios-systemd-whinlatter-$machine",
                        "oe-fragments": [
                            "meta-ankaios/ankaios/full-systemd"
                        ]
                    }
                ]
            }
        ]
    }
}