{
    "version": "1.0",
    "description": "Ankaios bitbake-setup profiles for Yocto 6.0 Wrynose",
    "sources": {
        "bitbake": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.openembedded.org/bitbake"
                    }
                },
                "branch": "2.18",
                "rev": "2.18"
            }
        },
        "openembedded-core": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.openembedded.org/openembedded-core"
                    }
                },
                "branch": "wrynose",
                "rev": "wrynose"
            }
        },
        "meta-yocto": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-yocto"
                    }
                },
                "branch": "wrynose",
                "rev": "wrynose"
            }
        },
        "meta-openembedded": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.openembedded.org/meta-openembedded"
                    }
                },
                "branch": "wrynose",
                "rev": "wrynose"
            }
        },
        "meta-virtualization": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-virtualization"
                    }
                },
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-raspberrypi": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-raspberrypi"
                    }
                },
                "branch": "master",
                "rev": "master"
            }
        }
    },
    "bitbake-setup": {
        "configurations": [
            {
                "bb-layers": [
                    "openembedded-core/meta",
                    "meta-yocto/meta-poky",
                    "meta-yocto/meta-yocto-bsp",
                    "meta-openembedded/meta-oe",
                    "meta-openembedded/meta-python",
                    "meta-openembedded/meta-networking",
                    "meta-openembedded/meta-filesystems",
                    "meta-virtualization",
                    "meta-raspberrypi"
                ],
                "bb-layers-file-relative": [
                    "."
                ],
                "oe-fragments": [
                    "distro/poky"
                ],
                "oe-fragments-one-of": {
                    "machine": {
                        "description": "Target machine",
                        "options": [
                            "machine/qemux86-64",
                            "machine/raspberrypi4-64",
                            "machine/raspberrypi5"
                        ]
                    }
                },
                "configurations": [
                    {
                        "name": "ankaios-sysvinit",
                        "description": "Poky distribution with Ankaios and SysVinit on Wrynose",
                        "setup-dir-name": "ankaios-sysvinit-wrynose-$machine",
                        "oe-fragments": [
                            "meta-ankaios/ankaios/minimal-sysvinit"
                        ]
                    },
                    {
                        "name": "ankaios-systemd",
                        "description": "Poky distribution with Ankaios and systemd on Wrynose",
                        "setup-dir-name": "ankaios-systemd-wrynose-$machine",
                        "oe-fragments": [
                            "meta-ankaios/ankaios/full-systemd"
                        ]
                    }
                ]
            }
        ]
    }
}