#!/bin/sh
# Custom udhcpc script - only update DNS

case "$1" in
    bound|renew)
        if [ -n "$dns" ]; then
            echo "Updating DNS servers: $dns"
            > /etc/resolv.conf
            for i in $dns; do
                echo "nameserver $i" >> /etc/resolv.conf
            done
        fi
        ;;
esac
